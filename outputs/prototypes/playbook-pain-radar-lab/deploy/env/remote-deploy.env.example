MELWATER_DEPLOY_HOST=1.2.3.4
MELWATER_DEPLOY_USER=ubuntu
MELWATER_DEPLOY_PORT=22
MELWATER_SSH_KEY_PATH=/Users/you/.ssh/tencent-cloud-melwater.pem

MELWATER_DEPLOY_PATH=/opt/melwater/playbook-pain-radar-lab
MELWATER_REMOTE_STATE_DIR=/var/lib/melwater/review-state
MELWATER_REMOTE_STAGE_ROOT=/tmp/melwater-deploy/releases
MELWATER_SERVICE_NAME=melwater-review-state-api
MELWATER_REMOTE_APP_USER=melwater
MELWATER_REMOTE_OWNER=melwater:melwater
MELWATER_REMOTE_USE_SUDO=1
MELWATER_EDGE_CONTAINER=ai_video_nginx
MELWATER_EDGE_RESTART_ENABLED=1
# Optional override (takes precedence over MELWATER_EDGE_CONTAINER when set):
# MELWATER_EDGE_REFRESH_CMD=docker restart ai_video_nginx

REVIEW_STATE_API_BASE=https://mkt.lute-tlz-dddd.top/api/review-state
REVIEW_STATE_VERIFY_TOKEN=replace-with-admin-token

PUBLIC_SITE_URL=https://mkt.lute-tlz-dddd.top
PUBLIC_SITE_EXPECT_TEXT=
