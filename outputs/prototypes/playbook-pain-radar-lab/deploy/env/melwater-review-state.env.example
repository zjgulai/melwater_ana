NODE_ENV=production
HOST=127.0.0.1
REVIEW_STATE_PORT=4174
REVIEW_STATE_DIR=/var/lib/melwater/review-state
REVIEW_STATE_CORS_ORIGIN=https://melwater.example.com
REVIEW_STATE_BACKUP_KEEP=14

# Prefer REVIEW_STATE_TOKENS for role-based production access.
# Store real values in Tencent Cloud secret/env management, not in git.
REVIEW_STATE_TOKENS={"viewer-token":{"role":"viewer","actor":"Ops Viewer"},"editor-token":{"role":"editor","actor":"Ops Editor"},"admin-token":{"role":"admin","actor":"Ops Admin"}}

# Used only by deployment self-check commands.
REVIEW_STATE_API_BASE=https://melwater.example.com/api/review-state
REVIEW_STATE_VERIFY_TOKEN=admin-token
