MELWATER_PUBLIC_ORIGIN=https://melwater.lute-tlz-dddd.top
REVIEW_STATE_BACKUP_KEEP=14
MELWATER_RELEASE_REF=development
MELWATER_BACKUP_HOST_ROOT=/opt/melwater-ana/backups
MELWATER_HEALTH_INCIDENT_THRESHOLD=3
MELWATER_HEALTH_INCIDENT_FILE=/opt/melwater-ana/backups/health-incident.json
MELWATER_HEALTH_ALERT_LOG=/opt/melwater-ana/backups/health-alerts.log
MELWATER_OPS_ROOT=/opt/melwater-ana/backups
MELWATER_OPS_REPORT_ROOT=/opt/melwater-ana/backups/ops-reports
MELWATER_OPS_REPORT_LATEST_JSON=/opt/melwater-ana/backups/ops-report-latest.json
MELWATER_OPS_REPORT_LATEST_MD=/opt/melwater-ana/backups/ops-report-latest.md
MELWATER_OPS_REPORT_DIR=/opt/melwater-ana/backups/ops-reports
MELWATER_OPS_REPORT_LATEST_JSON_FILE=/opt/melwater-ana/backups/ops-report-latest.json
MELWATER_OPS_REPORT_LATEST_MD_FILE=/opt/melwater-ana/backups/ops-report-latest.md

# Generate production tokens outside git:
# node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
REVIEW_STATE_HEALTH_TOKEN=replace-with-admin-token
REVIEW_STATE_TOKENS={"viewer-token":{"role":"viewer","actor":"Melwater Viewer"},"editor-token":{"role":"editor","actor":"Melwater Editor"},"admin-token":{"role":"admin","actor":"Melwater Admin"}}

# Optional healthcheck alert webhook. Types: generic, feishu, wecom.
MELWATER_ALERT_WEBHOOK_URL=
MELWATER_ALERT_WEBHOOK_TYPE=generic
MELWATER_ALERT_DRY_RUN=0
MELWATER_ALERT_TIMEOUT=15
MELWATER_ALERT_EXPECT_STATUS=2xx
MELWATER_ALERT_DRILL_ROOT=/opt/melwater-ana/backups/alert-drills
MELWATER_ALERT_DRILL_LATEST_JSON=/opt/melwater-ana/backups/alert-drill-latest.json
MELWATER_ALERT_DRILL_LATEST_MD=/opt/melwater-ana/backups/alert-drill-latest.md
MELWATER_ALERT_DRILL_RECOVERY_ATTEMPTS=8
MELWATER_ALERT_DRILL_RECOVERY_SLEEP=5
