{
  "name": "playbook-pain-radar-lab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "node server/reviewStateServer.mjs",
    "review:migrate": "node server/migrateReviewState.mjs",
    "review:replay": "node server/replayReviewEvents.mjs",
    "review:backup": "node server/backupReviewState.mjs",
    "review:prune-backups": "node server/pruneReviewBackups.mjs",
    "review:verify-deploy": "node server/verifyDeployment.mjs",
    "release:package": "node server/createReleasePackage.mjs",
    "release:verify": "node server/verifyReleasePackage.mjs",
    "deploy:preflight": "node server/remoteRelease.mjs --mode=preflight",
    "deploy:remote": "node server/remoteRelease.mjs --mode=deploy",
    "deploy:rollback": "node server/remoteRelease.mjs --mode=rollback",
    "deploy:verify-public": "node server/verifyPublicSite.mjs",
    "deploy:checklist": "bash deploy/scripts/melwater-prod-release-checklist.sh",
    "deploy:get-admin-token": "bash deploy/scripts/melwater-get-admin-token.sh",
    "deploy:orchestrate": "bash deploy/scripts/melwater-release-orchestrate.sh",
    "ops:healthcheck": "sh deploy/scripts/melwater-healthcheck.sh",
    "ops:report": "sh deploy/scripts/melwater-ops-report.sh",
    "ops:install-cron": "sh deploy/scripts/melwater-install-ops-cron.sh",
    "ops:alert-test": "sh deploy/scripts/melwater-alert-test.sh",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.44.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.8.1",
    "vite": "^8.0.16"
  }
}
